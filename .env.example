# ============================================================
# MediScan AI — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control!
# ============================================================

# --- AI API Keys ---

# GEMINI_API_KEY: Required for Gemini AI features (medicine scanning, chat, interactions)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# GROQ_API_KEY: Fallback AI inference when Gemini is unavailable
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY="YOUR_GROQ_API_KEY"

# --- External Service Keys ---

# OCR_SPACE_API_KEY: For image text extraction (prescription OCR)
# Get yours at: https://ocr.space/ocrapi
OCR_SPACE_API_KEY="YOUR_OCR_SPACE_API_KEY"

# OPENFDA_API_KEY: For FDA clinical medication data (optional, works without key at lower rate limits)
# Get yours at: https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY="YOUR_OPENFDA_API_KEY"

# --- Firebase Configuration ---
# These are used by the server (server.ts). For the client (Vite), prefix with VITE_.
# Alternative: create a firebase-applet-config.json file from the example template.

# Server-side Firebase config
FIREBASE_PROJECT_ID="YOUR_FIREBASE_PROJECT_ID"
FIREBASE_APP_ID="YOUR_FIREBASE_APP_ID"
FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
FIREBASE_AUTH_DOMAIN="YOUR_PROJECT_ID.firebaseapp.com"
FIREBASE_FIRESTORE_DB_ID="(default)"
FIREBASE_STORAGE_BUCKET="YOUR_PROJECT_ID.firebasestorage.app"
FIREBASE_MESSAGING_SENDER_ID="YOUR_MESSAGING_SENDER_ID"

# Client-side Firebase config (Vite exposes vars prefixed with VITE_)
VITE_FIREBASE_PROJECT_ID="YOUR_FIREBASE_PROJECT_ID"
VITE_FIREBASE_APP_ID="YOUR_FIREBASE_APP_ID"
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT_ID.firebaseapp.com"
VITE_FIREBASE_FIRESTORE_DB_ID="(default)"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT_ID.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_MESSAGING_SENDER_ID"

# --- App Configuration ---

# APP_URL: The URL where this app is hosted (used for links, callbacks)
APP_URL="http://localhost:3000"

# PORT: Server port (default: 3000)
PORT=3000
