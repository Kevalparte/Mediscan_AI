{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a registered user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "ScanHistory": {
      "title": "Scan History",
      "description": "A record of a prescription or medicine scanned by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "medicineName": { "type": "string" },
        "purpose": { "type": "string" },
        "dosage": { "type": "string" },
        "sideEffects": { "type": "string" },
        "precautions": { "type": "string" },
        "imageUrl": { "type": "string" },
        "rawText": { "type": "string" },
        "scannedAt": { "type": "string" }
      },
      "required": ["id", "userId", "medicineName", "scannedAt"]
    },
    "Reminder": {
      "title": "Dose Reminder",
      "description": "A scheduled medicine reminder set by a patient",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "medicineName": { "type": "string" },
        "dosage": { "type": "string" },
        "time": { "type": "string" },
        "frequency": { "type": "string" },
        "days": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "medicineName", "time", "isActive"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Unique user documents"
    },
    "/users/{userId}/history/{scanId}": {
      "schema": "ScanHistory",
      "description": "Scanned medicine results per user"
    },
    "/users/{userId}/reminders/{reminderId}": {
      "schema": "Reminder",
      "description": "Daily or scheduled reminders set by the user"
    }
  }
}
